# Copiar a .env y rellenar con valores reales (nunca commitear .env)
# Rotar keys si alguna vez estuvieron en el repositorio.

# Supabase — Auth anónima + tabla items
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Groq — clasificación de prendas + sugerencias de outfit
EXPO_PUBLIC_GROQ_API_KEY=your_groq_api_key

# OpenWeather — clima en Home y contexto de sugerencias
EXPO_PUBLIC_WEATHER_API_KEY=your_openweather_key
